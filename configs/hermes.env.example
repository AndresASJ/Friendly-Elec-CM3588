# Hermes Agent — secrets/config
# Real file lives at /mnt/drive1/AppData/hermes/hermes.env (chmod 600, git-ignored).
# Copy this to that path, fill in real values, then `chmod 600`.

# ---- Model: Google Gemini Flash (AI Studio key, starts with AIza... or AQ.) ----
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=google/gemini-3.5-flash

# ---- Telegram gateway ----
# Bot token from @BotFather. Use a DEDICATED bot — do not share with n8n's
# Telegram-trigger bot (only one getUpdates/webhook consumer per token).
TELEGRAM_BOT_TOKEN=000000000:your_bot_token_here
# Lock the agent to your own numeric Telegram user ID (from @userinfobot).
TELEGRAM_ALLOWED_USERS=000000000
# Default chat for proactive/cron deliveries (usually your own user ID).
TELEGRAM_HOME_CHANNEL=000000000
